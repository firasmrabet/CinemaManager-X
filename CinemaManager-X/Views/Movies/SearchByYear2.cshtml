@model IEnumerable<CinemaManager_X.Models.Cinema.Movie>

@{
    ViewData["Title"] = "Advanced Search - Genre and Title";
}

<h1>Advanced Search - Filter by Genre and Title</h1>

<p>
    <a asp-action="Index">Back to List</a>
</p>

<div class="form-group">
    <form asp-action="SearchByYear2" method="get">
        <div>
            <label for="searchGenre">Genre:</label>
            @Html.DropDownList("searchGenre", (SelectList)ViewData["Genres"], "All")

            <label for="searchTitle">Title:</label>
            <input type="text" id="searchTitle" name="searchTitle" value="@ViewData["SearchTitle"]"
            />

            <button type="submit">Find</button>
        </div>
    </form>
</div>

<div class="table-responsive mt-3">
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Title)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Genre)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Producer.Name)
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Title)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Genre)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Producer.Name)
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.Count() == 0)
{
    <p class="text-muted">Aucun film trouvé selon vos critères de recherche.</p>
}
