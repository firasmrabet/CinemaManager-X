@model CinemaManager_X.Models.Cinema.Producer

@{
    ViewData["Title"] = "Producer and Their Movies";
}

<h1>@Model.Name - Movies</h1>

<div class="card">
    <div class="card-body">
        <p><strong>Nationality:</strong> @Model.Nationality</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><a asp-action="Index">Back to Producers List</a></p>
    </div>
</div>

<h2>Movies by @Model.Name</h2>

@if (Model.Movies.Any())
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Movie Title</th>
                    <th>Genre</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var movie in Model.Movies)
                {
                    <tr>
                        <td>@movie.Title</td>
                        <td>@movie.Genre</td>
                        <td>
                            <a asp-controller="Movies" asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id" class="btn btn-info btn-sm">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p>No movies found for this producer.</p>
}
